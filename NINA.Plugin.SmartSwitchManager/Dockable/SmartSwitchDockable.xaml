<ResourceDictionary
    x:Class="NINA.Plugin.SmartSwitchManager.Dockable.SmartSwitchDockable"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="clr-namespace:NINA.Plugin.SmartSwitchManager.Dockable"
    mc:Ignorable="d">

    <!-- SVG Geometry for the top menu icon -->
    <GeometryGroup x:Key="NINA.Plugin.SmartSwitchManager_PowerSVG">
        <PathGeometry Figures="M16.56,5.44L15.11,6.89C16.84,7.94 18,9.83 18,12A6,6 0 0,1 12,18A6,6 0 0,1 6,12C6,9.83 7.16,7.94 8.88,6.88L7.44,5.44C5.36,6.88 4,9.28 4,12A8,8 0 0,0 12,20A8,8 0 0,0 20,12C20,9.28 18.64,6.88 16.56,5.44M11,3V13H13V3H11Z" />
    </GeometryGroup>

    <!-- Dockable UI for the Imaging Tab -->
    <!-- Key must match: <Namespace>.<ClassName>_Dockable -->
    <DataTemplate x:Key="NINA.Plugin.SmartSwitchManager.Dockable.SmartSwitchDockableVM_Dockable" DataType="{x:Type local:SmartSwitchDockableVM}">
        <Grid Background="{DynamicResource MahApps.Brushes.ThemeBackground}">
            <!-- If no switches are configured -->
            <TextBlock Text="No Smart Switches configured"
                       Foreground="{DynamicResource MahApps.Brushes.ThemeForeground}" 
                       TextAlignment="Center" VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Switches.Count}" Value="0">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <!-- Native Single Switch View (ComboBox) -->
            <StackPanel Margin="10,10,10,0">
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Switches.Count}" Value="0">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>
                
                <!-- Row 1: Name on Left, State (0/1) on Right -->
                <Grid Margin="0,0,0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <!-- Display Name of Selected Switch -->
                    <TextBlock Grid.Column="0" Text="{Binding SelectedSwitch.DisplayName}" VerticalAlignment="Center" />
                    
                    <!-- State Display (0 or 1) -->
                    <TextBlock Grid.Column="1" VerticalAlignment="Center" Margin="0,0,5,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                <Setter Property="Text" Value="0" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedSwitch.IsOn}" Value="True">
                                        <Setter Property="Text" Value="1" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding SelectedSwitch}" Value="{x:Null}">
                                        <Setter Property="Text" Value="-" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>

                <!-- Row 2: ComboBox to select the active switch -->
                <ComboBox ItemsSource="{Binding Switches}" 
                          SelectedItem="{Binding SelectedSwitch}" 
                          DisplayMemberPath="DisplayName" 
                          Margin="0,0,0,5" />

                <!-- Row 3: Native Toggle Button (Mirroring NINA AnchorableSwitchHubView) -->
                <Button Command="{Binding SelectedSwitch.ToggleCommand}"
                        IsEnabled="{Binding SelectedSwitch.IsBusy, Converter={StaticResource InverseBooleanConverter}}"
                        HorizontalAlignment="Right"
                        Height="25" MinWidth="85"
                        Margin="0,5,0,0">
                    <TextBlock Padding="5,0,5,0"
                               HorizontalAlignment="Center"
                               Foreground="{DynamicResource ButtonForegroundBrush}"
                               Text="Toggle" />
                </Button>
            </StackPanel>
        </Grid>
    </DataTemplate>
</ResourceDictionary>
