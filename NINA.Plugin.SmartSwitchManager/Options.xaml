<ResourceDictionary
    x:Class="NINA.Plugin.SmartSwitchManager.Options"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sys="clr-namespace:System;assembly=mscorlib"
    xmlns:models="clr-namespace:NINA.Plugin.SmartSwitchManager.Core.Models;assembly=NINA.Plugin.SmartSwitchManager.Core"
    xmlns:local="clr-namespace:NINA.Plugin.SmartSwitchManager"
    xmlns:converters="clr-namespace:NINA.Plugin.SmartSwitchManager.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <converters:StringToBoolConverter x:Key="StringToBoolConverter" />
    <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

    <!-- Dynamic Config Template Selector -->
    <converters:ConfigFieldTemplateSelector x:Key="ConfigFieldTemplateSelector">
        <converters:ConfigFieldTemplateSelector.TextTemplate>
            <DataTemplate DataType="{x:Type models:ConfigFieldViewModel}">
                <StackPanel Orientation="Horizontal" Margin="0,0,15,0" Visibility="{Binding IsVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBlock Text="{Binding Descriptor.Label, StringFormat='{}{0}:'}" 
                             Foreground="{DynamicResource SecondaryBrush}" VerticalAlignment="Center" Margin="0,0,5,0" FontSize="10" />
                    <TextBox Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}" Width="110" VerticalAlignment="Center">
                        <TextBox.Style>
                            <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsValid}" Value="False">
                                        <Setter Property="BorderBrush" Value="Red" />
                                        <Setter Property="ToolTip" Value="This field is required" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>
                </StackPanel>
            </DataTemplate>
        </converters:ConfigFieldTemplateSelector.TextTemplate>
        <converters:ConfigFieldTemplateSelector.PasswordTemplate>
            <DataTemplate DataType="{x:Type models:ConfigFieldViewModel}">
                <StackPanel Orientation="Horizontal" Margin="0,0,15,0" Visibility="{Binding IsVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBlock Text="{Binding Descriptor.Label, StringFormat='{}{0}:'}" 
                             Foreground="{DynamicResource SecondaryBrush}" VerticalAlignment="Center" Margin="0,0,5,0" FontSize="10" />
                    <!-- Using a TextBox for now, but configured as Password type in metadata -->
                    <TextBox Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}" Width="80" VerticalAlignment="Center">
                        <TextBox.Style>
                            <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsValid}" Value="False">
                                        <Setter Property="BorderBrush" Value="Red" />
                                        <Setter Property="ToolTip" Value="This field is required" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>
                </StackPanel>
            </DataTemplate>
        </converters:ConfigFieldTemplateSelector.PasswordTemplate>
        <converters:ConfigFieldTemplateSelector.NumberTemplate>
            <DataTemplate DataType="{x:Type models:ConfigFieldViewModel}">
                <StackPanel Orientation="Horizontal" Margin="0,0,15,0" Visibility="{Binding IsVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBlock Text="{Binding Descriptor.Label, StringFormat='{}{0}:'}" 
                             Foreground="{DynamicResource SecondaryBrush}" VerticalAlignment="Center" Margin="0,0,5,0" FontSize="10" />
                    <TextBox Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}" Width="40" VerticalAlignment="Center">
                        <TextBox.Style>
                            <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsValid}" Value="False">
                                        <Setter Property="BorderBrush" Value="Red" />
                                        <Setter Property="ToolTip" Value="This field is required" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>
                </StackPanel>
            </DataTemplate>
        </converters:ConfigFieldTemplateSelector.NumberTemplate>
        <converters:ConfigFieldTemplateSelector.BooleanTemplate>
            <DataTemplate>
                <StackPanel Orientation="Horizontal" Margin="0,0,15,0" Visibility="{Binding IsVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <CheckBox IsChecked="{Binding Value, Converter={StaticResource StringToBoolConverter}}" 
                              Content="{Binding Descriptor.Label}" 
                              Foreground="{DynamicResource SecondaryBrush}" 
                              VerticalAlignment="Center" 
                              FontSize="10" />
                </StackPanel>
            </DataTemplate>
        </converters:ConfigFieldTemplateSelector.BooleanTemplate>
    </converters:ConfigFieldTemplateSelector>


    <!-- Custom Style for a classic Checkmark (Hook) to avoid N.I.N.A. toggle switches -->
    <Style x:Key="ClassicCheckBox" TargetType="CheckBox">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <BulletDecorator Background="Transparent" Cursor="Hand">
                        <BulletDecorator.Bullet>
                            <Grid Width="16" Height="16">
                                <Border x:Name="Border" 
                                        BorderThickness="1" 
                                        BorderBrush="{TemplateBinding BorderBrush}" 
                                        Background="{TemplateBinding Background}" />
                                <Path x:Name="CheckMark"
                                      Width="10" Height="10"
                                      SnapsToDevicePixels="False"
                                      Stroke="{DynamicResource PrimaryBrush}"
                                      StrokeThickness="2"
                                      Data="M 0 5 L 3 8 L 9 0"
                                      Visibility="Collapsed" />
                            </Grid>
                        </BulletDecorator.Bullet>
                        <ContentPresenter Margin="5,0,0,0" VerticalAlignment="Center" />
                    </BulletDecorator>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="CheckMark" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Geometry x:Key="DeleteIcon">M19,4H15.5L14.5,3H9.5L8.5,4H5V6H19V4M6,19A2,2 0 0,0 8,21H16A2,2 0 0,0 18,19V7H6V19Z</Geometry>

    <!--
        Plugin options page: N.I.N.A. → Options → Plugins → "Smart Switch Manager"
        Key MUST match: "<AssemblyTitle>_Options"
        DataContext = SmartSwitchPlugin instance.
    -->
    <DataTemplate x:Key="Smart Switch Manager_Options">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Orientation="Vertical" Margin="10">

                <!-- Header -->
                <TextBlock Text="Smart Switch Manager"
                           FontSize="18" FontWeight="Bold" Margin="0,0,0,5"
                           Foreground="{DynamicResource PrimaryBrush}" />
                <TextBlock Text="Smart Switch Manager lets you control smart home switches (Shelly, Tasmota, HA, ESPHome) directly from N.I.N.A."
                           FontSize="12" Foreground="{DynamicResource SecondaryBrush}" Margin="0,0,0,15" TextWrapping="Wrap" />

                <!-- Global Settings -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                    <TextBlock Text="HTTP Timeout:" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="{DynamicResource PrimaryBrush}" FontWeight="SemiBold" />
                    <TextBox Text="{Binding TimeoutSeconds, UpdateSourceTrigger=PropertyChanged}" Width="40" VerticalAlignment="Center" ToolTip="Timeout in seconds for network requests (1-60)" />
                    <TextBlock Text="seconds" VerticalAlignment="Center" Margin="5,0,0,0" Foreground="{DynamicResource SecondaryBrush}" FontSize="11" />
                </StackPanel>

                <TextBlock Text="Smart Switches" FontWeight="Bold" FontSize="14" Margin="0,0,0,10" 
                           Foreground="{DynamicResource PrimaryBrush}" />

                <!-- Configured Switch List with Table Layout -->
                <StackPanel Grid.IsSharedSizeScope="True">
                    <!-- Table Header -->
                    <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="0,0,0,5" Margin="0,0,0,5">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" SharedSizeGroup="ColName" />
                                <ColumnDefinition Width="Auto" SharedSizeGroup="ColProvider" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" SharedSizeGroup="ColAction" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Name" Margin="0,0,15,0" FontWeight="SemiBold" Foreground="{DynamicResource SecondaryBrush}" FontSize="11" />
                            <TextBlock Grid.Column="1" Text="Provider" Margin="0,0,15,0" FontWeight="SemiBold" Foreground="{DynamicResource SecondaryBrush}" FontSize="11" />
                            <TextBlock Grid.Column="2" Text="Configuration" Margin="0,0,15,0" FontWeight="SemiBold" Foreground="{DynamicResource SecondaryBrush}" FontSize="11" />
                        </Grid>
                    </Border>

                    <ItemsControl x:Name="ConfigItemsControl" ItemsSource="{Binding SmartSwitchConfigs}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:SmartSwitchConfig}">
                                <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,0.5" Padding="0,4">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        
                                        <!-- Row 0: The actual switch configuration row -->
                                        <Grid Grid.Row="0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" SharedSizeGroup="ColName" />
                                                <ColumnDefinition Width="Auto" SharedSizeGroup="ColProvider" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" SharedSizeGroup="ColAction" />
                                            </Grid.ColumnDefinitions>

                                            <!-- Name -->
                                            <TextBox Grid.Column="0" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Width="150" Margin="0,0,15,0" VerticalAlignment="Center" />
                                            
                                            <!-- Provider Selection -->
                                            <ComboBox Grid.Column="1" 
                                                      ItemsSource="{Binding DataContext.DiscoveredProviders, ElementName=ConfigItemsControl}"
                                                      DisplayMemberPath="DisplayName"
                                                      SelectedValuePath="ProviderId"
                                                      SelectedValue="{Binding ProviderType}"
                                                      Width="120" Margin="0,0,15,0" VerticalAlignment="Center" />

                                            <!-- Adaptive Configuration Content -->
                                            <ContentControl Grid.Column="2" Content="{Binding}" VerticalAlignment="Center">
                                                <ContentControl.Resources>
                                                    <DataTemplate x:Key="GenericConfigTemplate">
                                                        <StackPanel Orientation="Horizontal">
                                                            <!-- Dynamic Fields -->
                                                            <ItemsControl ItemsSource="{Binding ConfigViewModels}"
                                                                          ItemTemplateSelector="{StaticResource ConfigFieldTemplateSelector}">
                                                                <ItemsControl.ItemsPanel>
                                                                    <ItemsPanelTemplate>
                                                                        <StackPanel Orientation="Horizontal" />
                                                                    </ItemsPanelTemplate>
                                                                </ItemsControl.ItemsPanel>
                                                            </ItemsControl>

                                                            <!-- Scan Button (Hardware capability based) -->
                                                            <Button Command="{Binding DataContext.OpenScannerCommand, ElementName=ConfigItemsControl}"
                                                                    CommandParameter="{Binding}"
                                                                    Visibility="{Binding ProviderMetadata.SupportsScanning, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                                    ToolTip="Scan network for this device"
                                                                    Width="24" Height="24"
                                                                    Style="{DynamicResource StandardButton}"
                                                                    VerticalAlignment="Center"
                                                                    Cursor="Hand">
                                                                <TextBlock Text="🔍" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                            </Button>
                                                            
                                                            <!-- Expert Mode Toggle (Visible only if Provider has Expert fields) -->
                                                            <CheckBox IsChecked="{Binding ExpertModeEnabled}" 
                                                                      Content="⚙️ Expert" ToolTip="Toggle Expert Settings"
                                                                      Visibility="{Binding HasExpertFields, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                                      Style="{StaticResource ClassicCheckBox}"
                                                                      Foreground="{DynamicResource SecondaryBrush}"
                                                                      VerticalAlignment="Center" Margin="5,0,0,0" FontSize="10" />
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </ContentControl.Resources>
                                                <ContentControl.Style>
                                                     <Style TargetType="ContentControl">
                                                         <Setter Property="ContentTemplate" Value="{StaticResource GenericConfigTemplate}" />
                                                     </Style>
                                                </ContentControl.Style>
                                            </ContentControl>

                                            <!-- Delete Button -->
                                            <Button Grid.Column="3"
                                                     Command="{Binding DataContext.RemoveSwitchCommand, ElementName=ConfigItemsControl}"
                                                     CommandParameter="{Binding}"
                                                    ToolTip="Remove this switch"
                                                    Width="28" Height="24"
                                                    Style="{DynamicResource StandardButton}"
                                                    VerticalAlignment="Center"
                                                    Cursor="Hand">
                                                <Path Data="{StaticResource DeleteIcon}" Fill="#CC0000" Stretch="Uniform" Width="12" Height="12" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Button>
                                        </Grid>

                                        <!-- Row 1: The Scanner Inline Popup -->
                                        <Border Grid.Row="1" Background="{DynamicResource MenuBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" 
                                                Margin="0,10,0,5" Padding="15" CornerRadius="4"
                                                Visibility="{Binding IsScannerOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <StackPanel>
                                                <Grid Margin="0,0,0,10">
                                                    <TextBlock Text="{Binding ProviderType, StringFormat='Network Scanner ({0})'}" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryBrush}" VerticalAlignment="Center" />
                                                     <Button Command="{Binding DataContext.CloseScannerCommand, ElementName=ConfigItemsControl}"
                                                              CommandParameter="{Binding}"
                                                            HorizontalAlignment="Right" VerticalAlignment="Center"
                                                            Background="Transparent" BorderThickness="0" Cursor="Hand"
                                                            ToolTip="Close Scanner">
                                                        <TextBlock Text="✕" FontSize="14" Foreground="{DynamicResource SecondaryBrush}" />
                                                     </Button>
                                                </Grid>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                                        <TextBlock Text="IP Address" FontSize="10" Foreground="{DynamicResource SecondaryBrush}" />
                                                         <TextBox Text="{Binding DataContext.ScanIpAddress, ElementName=ConfigItemsControl, UpdateSourceTrigger=PropertyChanged}" Width="120" />
                                                     </StackPanel>
                                                     <StackPanel Grid.Column="1" Margin="0,0,10,0">
                                                         <TextBlock Text="Username (optional)" FontSize="10" Foreground="{DynamicResource SecondaryBrush}" />
                                                         <TextBox Text="{Binding DataContext.ScanUsername, ElementName=ConfigItemsControl, UpdateSourceTrigger=PropertyChanged}" Width="100" />
                                                     </StackPanel>
                                                     <StackPanel Grid.Column="2" Margin="0,0,10,0">
                                                         <TextBlock Text="Password (optional)" FontSize="10" Foreground="{DynamicResource SecondaryBrush}" />
                                                         <TextBox Text="{Binding DataContext.ScanPassword, ElementName=ConfigItemsControl, UpdateSourceTrigger=PropertyChanged}" Width="100" />
                                                     </StackPanel>
                                                     <Grid Grid.Column="3" VerticalAlignment="Bottom">
                                                         <!-- Scan Button -->
                                                         <Button Command="{Binding DataContext.ScanCommand, ElementName=ConfigItemsControl}" 
                                                                 CommandParameter="{Binding}" Height="22" Cursor="Hand">
                                                             <TextBlock Text="Scan Device" Padding="15,0" Foreground="{DynamicResource ButtonForegroundBrush}" />
                                                             <Button.Style>
                                                                 <Style TargetType="Button" BasedOn="{StaticResource StandardButton}">
                                                                     <Style.Triggers>
                                                                         <DataTrigger Binding="{Binding DataContext.IsScanning, ElementName=ConfigItemsControl}" Value="True">
                                                                             <Setter Property="Visibility" Value="Collapsed" />
                                                                         </DataTrigger>
                                                                     </Style.Triggers>
                                                                 </Style>
                                                             </Button.Style>
                                                         </Button>
                                                         <!-- Cancel Button -->
                                                         <Button Command="{Binding DataContext.CancelScanCommand, ElementName=ConfigItemsControl}" 
                                                                 Height="22" Cursor="Hand">
                                                             <TextBlock Text="Cancel Scan" Padding="15,0" Foreground="#CC0000" FontWeight="Bold" />
                                                             <Button.Style>
                                                                 <Style TargetType="Button" BasedOn="{StaticResource StandardButton}">
                                                                     <Setter Property="Visibility" Value="Collapsed" />
                                                                     <Style.Triggers>
                                                                         <DataTrigger Binding="{Binding DataContext.IsScanning, ElementName=ConfigItemsControl}" Value="True">
                                                                             <Setter Property="Visibility" Value="Visible" />
                                                                         </DataTrigger>
                                                                     </Style.Triggers>
                                                                 </Style>
                                                             </Button.Style>
                                                         </Button>
                                                     </Grid>
                                                </Grid>

                                                <!-- Scan Results Info -->
                                                 <TextBlock Text="{Binding DataContext.ScanResultMessage, ElementName=ConfigItemsControl}" Foreground="{DynamicResource PrimaryBrush}" Margin="0,10,0,5">
                                                     <TextBlock.Style>
                                                         <Style TargetType="TextBlock">
                                                             <Setter Property="Visibility" Value="Visible" />
                                                             <Style.Triggers>
                                                                 <DataTrigger Binding="{Binding DataContext.ScanResultMessage, ElementName=ConfigItemsControl}" Value="{x:Null}">
                                                                     <Setter Property="Visibility" Value="Collapsed" />
                                                                 </DataTrigger>
                                                                 <DataTrigger Binding="{Binding DataContext.ScanResultMessage, ElementName=ConfigItemsControl}" Value="">
                                                                     <Setter Property="Visibility" Value="Collapsed" />
                                                                 </DataTrigger>
                                                             </Style.Triggers>
                                                         </Style>
                                                     </TextBlock.Style>
                                                 </TextBlock>

                                                <!-- Discovered Switches List -->
                                                 <ItemsControl ItemsSource="{Binding DataContext.DiscoveredSwitches, ElementName=ConfigItemsControl}" Margin="0,5,0,10">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <StackPanel Orientation="Horizontal" Margin="0,2">
                                                                <CheckBox IsChecked="{Binding IsSelected}" VerticalAlignment="Center" Margin="0,0,10,0" ToolTip="Add this channel?" Style="{StaticResource ClassicCheckBox}" />
                                                                <TextBlock Text="{Binding SwitchInfo.Channel, StringFormat='[Ch {0}] '}" Width="45" VerticalAlignment="Center" Foreground="{DynamicResource PrimaryBrush}" />
                                                                <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Width="180" VerticalAlignment="Center" ToolTip="Name for Sequencer" />
                                                            </StackPanel>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>

                                                 <Button Command="{Binding DataContext.AddSelectedCommand, ElementName=ConfigItemsControl}" 
                                                         CommandParameter="{Binding}" HorizontalAlignment="Left" Cursor="Hand">
                                                     <TextBlock Text="Add Selected" Padding="15,4" Foreground="{DynamicResource ButtonForegroundBrush}" />
                                                     <Button.Style>
                                                         <Style TargetType="Button" BasedOn="{StaticResource StandardButton}">
                                                             <Setter Property="Visibility" Value="Visible" />
                                                             <Style.Triggers>
                                                                 <DataTrigger Binding="{Binding DataContext.DiscoveredSwitches.Count, ElementName=ConfigItemsControl}" Value="0">
                                                                     <Setter Property="Visibility" Value="Collapsed" />
                                                                 </DataTrigger>
                                                             </Style.Triggers>
                                                         </Style>
                                                     </Button.Style>
                                                 </Button>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,0.5" Padding="0,8" Margin="0,2,0,20">
                        <Button Command="{Binding AddSwitchCommand}"
                                Background="Transparent" BorderThickness="0"
                                Cursor="Hand" HorizontalAlignment="Left" Margin="5,0,0,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="+" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}" VerticalAlignment="Center" Margin="0,0,8,0" />
                                <TextBlock Text="Configure New Switch" Foreground="{DynamicResource PrimaryBrush}" VerticalAlignment="Center" Opacity="0.8" />
                            </StackPanel>
                        </Button>
                    </Border>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </DataTemplate>
</ResourceDictionary>
