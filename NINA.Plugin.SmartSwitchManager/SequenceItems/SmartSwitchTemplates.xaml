<ResourceDictionary
    x:Class="NINA.Plugin.SmartSwitchManager.SequenceItems.SmartSwitchTemplates"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:NINA.Plugin.SmartSwitchManager.SequenceItems"
    xmlns:mini="clr-namespace:NINA.View.Sequencer.MiniSequencer;assembly=NINA.Sequencer"
    xmlns:nina="clr-namespace:NINA.View.Sequencer;assembly=NINA.Sequencer">

    <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

    <!-- Normal Sequencer View -->
    <DataTemplate DataType="{x:Type local:SmartSwitchInstruction}">
        <nina:SequenceBlockView>
            <nina:SequenceBlockView.SequenceItemContent>
                <Grid Margin="5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="Switch:" VerticalAlignment="Center" Margin="0,0,5,0" />
                    <ComboBox Grid.Column="1" 
                              ItemsSource="{Binding AvailableSwitches}" 
                              SelectedValue="{Binding SelectedSwitchId, Mode=TwoWay}"
                              SelectedValuePath="Id"
                              DisplayMemberPath="Name" 
                              MinWidth="120" Margin="0,0,10,0" />

                    <StackPanel Grid.Column="2" Orientation="Horizontal" 
                                Visibility="{Binding IsDelaySupported, Converter={StaticResource BooleanToVisibilityConverter}}"
                                Margin="0,0,15,0">
                        <TextBlock Text="Delay (s):" VerticalAlignment="Center" Margin="0,0,5,0" />
                        <TextBox Text="{Binding DelaySeconds, UpdateSourceTrigger=PropertyChanged}" 
                                 Width="45" VerticalAlignment="Center" />
                    </StackPanel>
                    
                    <CheckBox Grid.Column="3" 
                              Content="Turn ON" 
                              IsChecked="{Binding TurnOn, Mode=TwoWay}" 
                              VerticalAlignment="Center" />
                </Grid>
            </nina:SequenceBlockView.SequenceItemContent>
        </nina:SequenceBlockView>
    </DataTemplate>

    <!-- Mini Sequencer View -->
    <DataTemplate x:Key="NINA.Plugin.SmartSwitchManager.SequenceItems.SmartSwitchInstruction_Mini">
        <mini:MiniSequenceItem>
            <mini:MiniSequenceItem.SequenceItemContent>
                <StackPanel Orientation="Horizontal" Margin="5,0,0,0">
                    <TextBlock Text="Smart Switch: " VerticalAlignment="Center" FontWeight="Bold"/>
                    <TextBlock Text="{Binding SwitchName}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock Text="{Binding TargetStateText}" VerticalAlignment="Center" />
                </StackPanel>
            </mini:MiniSequenceItem.SequenceItemContent>
        </mini:MiniSequenceItem>
    </DataTemplate>
</ResourceDictionary>
